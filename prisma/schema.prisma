generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  videogame
  book
  comic
  tcg
  figure
  boardgame
  lego
  movie
  other
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  passwordHash     String
  createdAt        DateTime @default(now())

  plan             String   @default("free")
  premiumStartedAt DateTime?

  items            Item[]
}

model Item {
  id             String   @id @default(uuid())
  name           String
  category       String
  estimatedPrice Decimal
  quantity       Int

  marketValue         Decimal?
  valuationSource     String?
  valuationConfidence Float?
  lastValuationAt     DateTime?

  condition      String?
  notes          String?
  platform       String?
  completeness   String?
  region         String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  snapshots      ItemValuationSnapshot[]
}

model ItemValuationSnapshot {
  id          String   @id @default(uuid())
  itemId      String
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)

  source      String
  marketValue Decimal
  confidence  Float?

  recordedAt  DateTime @default(now())
}