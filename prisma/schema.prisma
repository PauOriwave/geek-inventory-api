generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Category {
  videogame
  book
  comic
  tcg
  figure
  other
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  items        Item[]
}

model Item {
  id             String   @id @default(uuid())
  name           String
  category       String
  estimatedPrice Decimal
  quantity       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  condition      String?
  notes          String?
  platform       String?
  completeness   String?

  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}